<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boolean</title>
</head>
<body>
    <input id="input1" type="text" placeholder="Input 1">
<input id="input2" type="text" placeholder="Input 2">

<button onclick="checkBoolean()">Boolean Value</button>

<p id="result"></p>

<script>
function checkBoolean() {
    let input1 = document.getElementById("input1").value;
    let input2 = document.getElementById("input2").value;

    console.log("input_1 =", input1, "type =", typeof input1);
    console.log("input_2 =", input2, "type =", typeof input2);

    let result = (input1 === input2);

    console.log("Result =", result, "type =", typeof result);

    document.getElementById("result").innerText = result;
}
</script>
</body>
</html>
