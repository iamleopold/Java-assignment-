<body>
    <h1>Find Your K-Pop Idol Twin</h1>
    <p>Enter your 4-letter MBTI to see which Idol matches your personality.</p>
    <label>Your MBTI</label><br />
    <input 
    type="text"
    id="user-mbti"
    placeholder="e.g.,INFP"
    maxlength="4"
    /><br/><br/>

<button id="button1">Find My Twin</button>

<br/><br/>

<strong>Your Idol Twin :</strong> <span id="Idol-result">None yet</span>
<script src="functionscode.js">
</script>
